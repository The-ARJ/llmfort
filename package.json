{
  "name": "@the-arj/llmfort",
  "version": "0.6.2",
  "description": "Helpers for the boring-but-important code around every LLM API call: prompt safety, cost budgets, structured JSON output, conversation trimming, retry, and tool schemas. Works with OpenAI, Anthropic, and Gemini. Zero runtime dependencies.",
  "keywords": [
    "llm", "ai", "openai", "anthropic", "claude", "gemini", "chatgpt", "gpt-5",
    "tool-calling", "function-calling", "json-schema", "structured-output",
    "prompt-injection", "prompt-safety", "pii", "pii-detection", "jailbreak",
    "cost-guard", "token-budget", "llm-cost",
    "context-trim", "conversation-history",
    "rate-limit", "retry", "429", "backoff",
    "json-repair", "claude-prefill", "prompt-caching",
    "zod", "valibot", "ajv",
    "typescript", "nodejs", "zero-dependencies"
  ],
  "author": "The-ARJ",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tool-schema": {
      "import": {
        "types": "./dist/tool-schema/index.d.ts",
        "default": "./dist/tool-schema/index.mjs"
      },
      "require": {
        "types": "./dist/tool-schema/index.d.cts",
        "default": "./dist/tool-schema/index.cjs"
      }
    },
    "./prompt-safe": {
      "import": {
        "types": "./dist/prompt-safe/index.d.ts",
        "default": "./dist/prompt-safe/index.mjs"
      },
      "require": {
        "types": "./dist/prompt-safe/index.d.cts",
        "default": "./dist/prompt-safe/index.cjs"
      }
    },
    "./cost-guard": {
      "import": {
        "types": "./dist/cost-guard/index.d.ts",
        "default": "./dist/cost-guard/index.mjs"
      },
      "require": {
        "types": "./dist/cost-guard/index.d.cts",
        "default": "./dist/cost-guard/index.cjs"
      }
    },
    "./struct-out": {
      "import": {
        "types": "./dist/struct-out/index.d.ts",
        "default": "./dist/struct-out/index.mjs"
      },
      "require": {
        "types": "./dist/struct-out/index.d.cts",
        "default": "./dist/struct-out/index.cjs"
      }
    },
    "./context-trim": {
      "import": {
        "types": "./dist/context-trim/index.d.ts",
        "default": "./dist/context-trim/index.mjs"
      },
      "require": {
        "types": "./dist/context-trim/index.d.cts",
        "default": "./dist/context-trim/index.cjs"
      }
    },
    "./retry-llm": {
      "import": {
        "types": "./dist/retry-llm/index.d.ts",
        "default": "./dist/retry-llm/index.mjs"
      },
      "require": {
        "types": "./dist/retry-llm/index.d.cts",
        "default": "./dist/retry-llm/index.cjs"
      }
    },
    "./error-normalize": {
      "import": {
        "types": "./dist/error-normalize/index.d.ts",
        "default": "./dist/error-normalize/index.mjs"
      },
      "require": {
        "types": "./dist/error-normalize/index.d.cts",
        "default": "./dist/error-normalize/index.cjs"
      }
    },
    "./cache-key": {
      "import": {
        "types": "./dist/cache-key/index.d.ts",
        "default": "./dist/cache-key/index.mjs"
      },
      "require": {
        "types": "./dist/cache-key/index.d.cts",
        "default": "./dist/cache-key/index.cjs"
      }
    },
    "./stream-tools": {
      "import": {
        "types": "./dist/stream-tools/index.d.ts",
        "default": "./dist/stream-tools/index.mjs"
      },
      "require": {
        "types": "./dist/stream-tools/index.d.cts",
        "default": "./dist/stream-tools/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "tool-schema":      ["./dist/tool-schema/index.d.cts"],
      "prompt-safe":      ["./dist/prompt-safe/index.d.cts"],
      "cost-guard":       ["./dist/cost-guard/index.d.cts"],
      "struct-out":       ["./dist/struct-out/index.d.cts"],
      "context-trim":     ["./dist/context-trim/index.d.cts"],
      "retry-llm":        ["./dist/retry-llm/index.d.cts"],
      "error-normalize":  ["./dist/error-normalize/index.d.cts"],
      "cache-key":        ["./dist/cache-key/index.d.cts"],
      "stream-tools":     ["./dist/stream-tools/index.d.cts"]
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-ARJ/llmfort.git"
  },
  "bugs": { "url": "https://github.com/The-ARJ/llmfort/issues" },
  "homepage": "https://github.com/The-ARJ/llmfort#readme"
}
